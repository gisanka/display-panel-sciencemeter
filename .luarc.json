{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "runtime": {
    "version": "Lua5.2",
    "requirePattern": ["?", "?.lua"]
  },
  "workspace": {
    "library": [
      "c:\\Users\\ml\\AppData\\Roaming\\Code\\User\\workspaceStorage\\71b5ce97013221dbb82832110af7ddb6\\justarandomgeek.factoriomod-debug\\emmylua\\factorio\\library",
      "C:\\Users\\ml\\Documents\\GitHub"
    ],
    "moduleMap": [
      {
        "pattern": "^__(.*)__(.*)$",
        "replace": "$1$2"
      },
      {
        "pattern": "^(.*)\\.lua$",
        "replace": "$1"
      }
    ]
  },
  "diagnostics": {
    "globals": ["__DebugAdapter"],
    "disable": ["unnecessary-if"],
    "severity": {
      "undefined-global": "warning",
      "unused": "hint"
    },
    "enables": ["unknown-doc-tag"]
  }
}
